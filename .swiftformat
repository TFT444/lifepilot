--swiftversion 5.10
--indent 4
--maxwidth 120
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--closingparen balanced
--self remove
--importgrouping testable-bottom
--exclude .build,packages

# Disabled rules and why:
# - redundantReturn, extensionAccessControl, wrapPropertyBodies,
#   conditionalAssignment, numberFormatting: stylistic preferences that
#   don't affect correctness; kept off to avoid churn on existing code.
# - indent: SwiftFormat's indent tracking disagrees with this codebase's
#   #if/#elseif/#endif conditional-compilation blocks (see
#   DesignSystem/Tokens/Color+LifePilot.swift and
#   AppShell/Navigation/RootTabView.swift) — a known SwiftFormat limitation
#   around preprocessor directives, not a real formatting defect.
--disable redundantReturn,extensionAccessControl,wrapPropertyBodies,conditionalAssignment,numberFormatting,indent,hoistAwait
